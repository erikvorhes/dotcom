---js
const pagination = {
  data: 'collections',
  size: 1,
  alias: 'tag',
  filter: ['all', 'note', 'notes', 'luc_274_086', 'luc_288_081', 'luc_110_104', 'luc_105_053', 'luc_106_053'],
};

const eleventyExcludeFromCollections = true;

const eleventyComputed = {
  title: "Tagged ‘{{ tag }}’",
  permalink: function(data) {
    return `/has/${this.slugify(data.tag)}/`;
  },
};

const layout = 'layouts/base.njk';
---

<h1>Tagged ‘{{ tag }}’</h1>

<ul role="list" class="flow">
{%- for item in collections[ tag ] -%}
  {%- set t -%}
    {% renderTemplate 'md' %}{{ item.title | string }}{% endrenderTemplate %}
  {%- endset -%}
  <li>
    <h2><a href="{{ item.url }}">{{ t | stripOuterParagraph | safe }}</a></h2>
  {%- if item.course -%}
    <p><i>from {{ item.course }}</i></p>
  {%- else -%}
    <p class="pubdate"><time datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time></p>
  {%- endif -%}
  {%- if item.summary -%}
    {{ item.summary | renderContent('md') | safe }}
  {%- endif -%}
  </li>
{%- endfor -%}
</ul>