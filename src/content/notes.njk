---
title: Note Archive
eleventyNavigation:
  key: Note Archive
  order: 3
layout: layouts/base.njk
noindex: true
---

<div class="flow">
{%- for note in collections.notes | reverse -%}
  <article class="flow">
    <h2><a href="{{ note.url }}">{{ note.data.title | renderContent('md') | stripOuterParagraph | safe }}</a></h2>
    <p class="pubdate"><time datetime="{{ note.date | htmlDateString }}">{{ note.date | readableDate }}</time></p>
  {%- if note.data.summary -%}
    {{ note.data.summary | renderContent('md') | safe }}
  {%- endif -%}
  </article>
{%- endfor -%}
</div>
