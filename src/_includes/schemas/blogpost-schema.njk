<script type="application/ld+json" eleventy:ignore>
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage"
    },
    "isPartOf": {
      "@id": "{{site.url}}#website"
    },
    "@id": "{{ site.url }}{{ page.url }}",
    "headline": "{{ title or site.title}}",
    "description": "{{ summary or introSummary or site.description }}",
    {%- if coverImage -%}
    "image": "{{ site.url }}{{ coverImage }}",
    {%- endif -%}
    "inLanguage": "{{ site.locale }}",
    "publisher": {
      "@type": "Person",
      "name": "{{ site.author.name }}",
      "url": "{{ site.url }}"
    },
    "author": {
      "@type": "Person",
      "name": "{{ site.author.name }}"
    },
    "datePublished": "{{ date | htmlDateString }}"
  }
</script>