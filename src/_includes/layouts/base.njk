<!DOCTYPE html>
<html lang="en-us">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{{ title or metadata.title | striptags }}</title>
  <meta name="description" content="{{ summary or metadata.description | striptags }}">
  
  <meta name="generator" content="{{ eleventy.generator }}">
  
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ 'Home' if page.url == '/' else title or metadata.title }}">
  <meta property="og:description" content="{{ summary or metadata.description | striptags }}">
  <meta property="og:image" content="{{ metadata.url }}{% if image %}{{ image }}{% else %}{% ogImage page.date %}{% endif %}">
  <meta content="og:image:alt" content="">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="{{ metadata.title }}">

  <link rel="icon" type="image/svg+xml" href="/icon.svg">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png">

  <link rel="me" href="https://typo.social/@erikvorhes">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed.xml">
  <link rel="alternate" type="application/json" title="{{ site.title }}" href="/feed.json">

  {% css 'print' %}
    {% include 'css/print.css' %}
  {% endcss %}
  <style>
    {% include 'css/base.css' %}
    {% include 'css/nav.css' %}
    {% include 'css/footer.css' %}
    {% include 'css/content.css' %}
    {% include 'css/dl.css' %}
    {% include 'css/verse.css' %}
  </style>
  <script>
    {% include 'js/onLoad.js' %}
    {% include 'js/focusHash.js' %}
  </script>
  <link rel="stylesheet" href="https://use.typekit.net/arf4vwx.css">
{%- if page.url == '/has/' -%}
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
{%- endif -%}
  <style>{% getBundle 'css' %}</style>
  <link rel="stylesheet" href="{% getBundleFileUrl 'css', 'print' %}" media="print">
  <script eleventy:ignore>
    {% include 'js/handleColorSchemeData.js' %}
  </script>
</head>
<body>
  {% include 'partials/site_nav.njk' -%}
  <main{{ ' data-pagefind-ignore' if noindex }}>
{{ content | safe }}
  </main>
  <footer class="site__footer flow">
    <p>Copyright &copy; {% currentYear %} Erik Vorhes, all rights reserved. See the <a href="/is/#colophon">colophon</a> for more about how this all works.</p>
    <p><i>If you notice anything amiss, <a href="https://github.com/erikvorhes/dotcom/blob/main/src/content/{{ page.inputPath | stripDotSlash }}" target="_blank" rel="noopener noreferrer">please make a pull request</a>!</i></p>
  </footer>
  <!-- Page `{{ page.url }}` was built on {% currentBuildDate %} -->
  <script src="{% getBundleFileUrl 'js' %}"></script>
{%- if page.url == '/has/' -%}
  <script src="/pagefind/pagefind-ui.js" eleventy:ignore></script>
{%- endif -%}
</body>
</html>
