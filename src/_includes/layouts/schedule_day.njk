---
layout: layouts/page.njk
---

<style>
  .nav__course__day {
    margin-block: 3lh;
  }
  
  .nav__course__day p {
    font-size: calc(1rem / var(--type-scale));
    font-style: italic;
    text-align: end;
  }
</style>

{%- if notice -%}
  {{ notice | renderContent('md') | safe }}
  {{ notice }}
{%- endif -%}
{%- if reading -%}
  <h2>Reading</h2>
  {{ reading | renderContent('md') | safe }}
{%- endif -%}
{%- if content -%}
  <h2>Notes</h2>
{{ content | safe }}
{%- endif -%}

<nav class="nav__course__day">
  <p><a href="../#{{ date | monthDay | slugify }}">Back to the schedule</a></p>
</nav>
