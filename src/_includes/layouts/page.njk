---js
const layout = 'layouts/base.njk';

const eleventyComputed = {
  courseHome: function({ courseKey }) {
    if (!courseKey) {
      return undefined;
    }

    let courseSlug;
    switch (courseKey) {
      case 'luc-288-081':
        courseSlug = 'nature-literature';
        break;
      case 'luc-274-086':
        courseSlug = 'shakespeare';
        break;
      case 'luc-105-053':
        courseSlug = 'writing-1';
        break;
      case 'luc-106-053':
        courseSlug = 'writing-2';
        break;
      case 'luc-110-104':
        courseSlug = 'writing-seminar';
        break;
    }

    return `/was/teaching/${courseSlug}/`;
  }
};
---
{%- if courseKey -%}
  {% include 'partials/course_nav.njk' %}
{%- endif -%}
<article class="flow">
  <header class="{% if introSummary %}has-intro {% endif %}flow">
    <h1>{{ title | renderContent('md') | stripOuterParagraph | safe }}</h1>
    {% if datetime and pubDate %}<p class="pubdate"><time datetime="{{ datetime }}">{{ pubDate }}</time>{% endif %}
    {%- if introSummary -%}
      {{ introSummary | renderContent('md') | safe }}
    {%- endif -%}
  </header>
{{ content | safe }}
</article>