---
layout: layouts/base.njk
---

<style>
  :root {
    --column-width: calc((var(--site-inline-size) - 6lh) / 2);
  }

  main {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--column-width), 1fr));
    gap: 2lh;
  }
  .flow img {
    max-inline-size: var(--column-width);
    margin-inline: auto;
  }

  section h2 {
    margin-block-start: calc(2lh / 3);
  }
</style>

<div class="flow">
  <h1>Hello!</h1>
{{ content | safe }}
  <img src="./me.jpeg" alt="a recent picture of me">
</div>

<section class="flow">
  <h2><i>Recent notes</i></h2>
{%- for note in collections.notes | reverse | head(5) -%}
  <article class="flow">
    <h3><a href="{{ note.url }}">{{ note.data.title | renderContent('md') | stripOuterParagraph | safe }}</a></h3>
    <p class="pubdate"><time datetime="{{ note.date | htmlDateString }}">{{ note.date | readableDate }}</time></p>
  {%- if note.data.summary -%}
    {{ note.data.summary | renderContent('md') | safe }}
  {%- endif -%}
  </article>
{%- endfor -%}
  <p><i>You can find more notes in the <a href="/notes/">archive</a>.</i></p>
</section>
