{%- if page.url == '/menu/' -%}
{%- set scripts -%}{% include 'js/backButton.js' %}{%- endset -%}
<script>{{ scripts | jsmin | safe }}</script>
{%- endif -%}
<nav class="site__nav" aria-label="site navigation">
  <ul role="list">
    <li>
      <a href="/"{% if page.url == '/' %} aria-current="page"{% endif %} aria-labelledby="home-label">
        {{ metadata.title }}
        <span id="home-label" class="visually-hidden">(Home)</span>
      </a>
    </li>
    <li>
      <a href="/has/"{% if page.url == '/has/' %} aria-current="page"{% endif %} aria-labelledby="search-label" title="search">
        🔎
        <span id="search-label" class="visually-hidden">Search</span>
      </a>
    </li>
    {%- if page.url == '/menu/' -%}
    <li>
      <a href="/" id="back-button" aria-labelledby="back-label" title="close">
        ×
        <span id="back-label" class="visually-hidden"> Go home</span>
      </a>
    </li>
    {%- else -%}
    <li>
      <a href="/menu/" aria-labelledby="menu-label" title="menu">
        ≡
        <span id="menu-label" class="visually-hidden"> Menu</span>
      </a>
    </li>
    {%- endif -%}
  </ul>
</nav>
